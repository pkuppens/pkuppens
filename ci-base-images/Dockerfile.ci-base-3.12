# ci-base-3.12: minimal CI base with Python 3.12, uv, and lint/security tooling.
# Used as base for ci-hf-base-3.12 and ci-whisper-3.12 (sibling branches).
# See docs/ci-base-images.md for usage and version matrix.
FROM python:3.12-slim

LABEL org.opencontainers.image.documentation="https://github.com/pkuppens/pkuppens/blob/main/ci-base-images/README.md"
LABEL org.opencontainers.image.source="https://github.com/pkuppens/pkuppens"

WORKDIR /workspace

# C/C++ toolchain: consuming repos often run `uv sync` in CI and build native wheels (e.g. annoy).
# Derived images (ci-hf-base, ci-whisper) explicitly purge this after installs to save space for models.
RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN pip install --no-cache-dir uv

# Install minimal CI tooling: pytest, ruff, bandit, safety, pytest-cov
RUN uv pip install --system \
    pytest>=7.4.0 \
    pytest-cov>=4.0.0 \
    ruff>=0.11.0 \
    bandit>=1.7.0 \
    safety>=2.0.0

# Default working directory for jobs that use this image
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
